{
	"name": "luminabooks-server",
	"version": "0.1.0",
	"private": true,
	"main": "dist/server.js",
	"scripts": {
		"dev": "ts-node-dev --respawn --transpile-only src/server.ts",
		"build": "rimraf dist && tsc",
		"start": "node dist/server.js",
		"test": "jest --runInBand",
		"test:watch": "jest --watch",
		"test:coverage": "jest --coverage",
		"test:ci": "jest --ci --coverage --runInBand"
	},
	"dependencies": {
		"bcryptjs": "^3.0.3",
		"cors": "^2.8.6",
		"dotenv": "^17.3.1",
		"express": "^5.2.1",
		"jsonwebtoken": "^9.0.3",
		"mongoose": "^9.2.2"
	},
	"devDependencies": {
		"@types/bcryptjs": "^2.4.6",
		"@types/cors": "^2.8.17",
		"@types/express": "^5.0.6",
		"@types/jest": "^30.0.0",
		"@types/jsonwebtoken": "^9.0.6",
		"@types/node": "^25.3.0",
		"@types/supertest": "^6.0.3",
		"jest": "^30.2.0",
		"rimraf": "^6.1.3",
		"supertest": "^7.1.4",
		"ts-jest": "^29.4.5",
		"ts-node-dev": "^2.0.0",
		"typescript": "^5.9.3"
	}
}
