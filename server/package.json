{
	"name": "luminabooks-server",
	"version": "0.1.0",
	"private": true,
	"main": "dist/server.js",
	"scripts": {
		"dev": "ts-node-dev --respawn --transpile-only -r tsconfig-paths/register src/server.ts",
		"build": "rimraf dist && tsc",
		"start": "node dist/server.js",
		"test": "jest --runInBand",
		"test:watch": "jest --watch --runInBand",
		"test:coverage": "jest --coverage",
		"test:ci": "jest --ci --coverage --runInBand"
	},
	"dependencies": {
		"bcrypt": "^6.0.0",
		"bcryptjs": "^3.0.3",
		"cors": "^2.8.6",
		"dotenv": "^17.3.1",
		"express": "^5.2.1",
		"express-rate-limit": "^8.3.0",
		"express-validator": "^7.3.1",
		"jsonwebtoken": "^9.0.3",
		"mongoose": "^9.2.3",
		"multer": "^2.1.0",
		"nodemailer": "^8.0.1",
		"passport": "^0.7.0",
		"passport-jwt": "^4.0.1",
		"slugify": "^1.6.8",
		"tsconfig-paths": "^4.2.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@types/bcrypt": "^6.0.0",
		"@types/bcryptjs": "^2.4.6",
		"@types/cors": "^2.8.17",
		"@types/express": "^5.0.6",
		"@types/jest": "^30.0.0",
		"@types/jsonwebtoken": "^9.0.6",
		"@types/multer": "^2.0.0",
		"@types/node": "^25.3.0",
		"@types/nodemailer": "^7.0.11",
		"@types/passport": "^1.0.17",
		"@types/passport-jwt": "^4.0.1",
		"@types/supertest": "^6.0.3",
		"jest": "^30.2.0",
		"mongodb-memory-server": "^11.0.1",
		"rimraf": "^6.1.3",
		"supertest": "^7.1.4",
		"ts-jest": "^29.4.5",
		"ts-node-dev": "^2.0.0",
		"typescript": "^5.9.3"
	}
}
